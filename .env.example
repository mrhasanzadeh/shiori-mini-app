# Supabase Configuration (user list, notifications — until migrated to shiori-api)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Shiori REST API (catalog reads — when set, mini-app uses API instead of Supabase for catalog)
VITE_SHIORI_API_URL=http://localhost:4001
# نام ستون تصویر در جدول anime
# VITE_ANIME_IMAGE_COLUMN=cover_image

# Telegram bot username (share links + startapp)
# VITE_TELEGRAM_BOT_USERNAME=ShioriUploadBot

# Optional: IMDb score via OMDb (fallback: imdbapi.dev)
# VITE_OMDB_API_KEY=

# ─── Edge Function secrets (Supabase Dashboard) ───
# CRON_SECRET=
# OMDB_API_KEY=
