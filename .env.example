# Supabase Configuration
# Get these from your Supabase project settings
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# نام ستون تصویر در جدول anime (اگر با cover_image فرق داره اینجا بذار، مثلاً: poster یا image)
# VITE_ANIME_IMAGE_COLUMN=cover_image

# Admin Panel (Telegram allowlist — ignored when VITE_ADMIN_WEB_ONLY=true)
# VITE_ADMIN_TELEGRAM_IDS=90344148

# Admin Panel — web login via Supabase RPC (admin_portal_login)
# Do NOT set VITE_ADMIN_WEB_PASSWORD in production builds (removed from app)

# Web-only admin: panel works in browser only, blocked inside Telegram Mini App
# VITE_ADMIN_WEB_ONLY=true

# Telegram bot username (share links + startapp)
# VITE_TELEGRAM_BOT_USERNAME=ShioriUploadBot

# ─── Website (apps/website) — copy to apps/website/.env.local ───
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=ShioriUploadBot
# NEXT_PUBLIC_SITE_URL=https://shiori.ir
# NEXT_PUBLIC_ANIME_IMAGE_COLUMN=cover_image

# Optional: IMDb score via OMDb (fallback: imdbapi.dev)
# VITE_OMDB_API_KEY=

# ─── Edge Function: sync-external-scores (Supabase Dashboard → Edge Functions → Secrets) ───
# SUPABASE_URL=              (auto in Edge runtime)
# SUPABASE_SERVICE_ROLE_KEY=   (auto in Edge runtime)
# CRON_SECRET=                 (required in production for sync-external-scores)
# OMDB_API_KEY=                (optional)
