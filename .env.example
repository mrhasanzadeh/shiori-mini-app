# Supabase Configuration
# Get these from your Supabase project settings
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# نام ستون تصویر در جدول anime (اگر با cover_image فرق داره اینجا بذار، مثلاً: poster یا image)
# VITE_ANIME_IMAGE_COLUMN=cover_image

# Admin Panel (Telegram-only gate): comma-separated Telegram numeric user ids
# مثال: VITE_ADMIN_TELEGRAM_IDS=12345678,87654321
# VITE_ADMIN_TELEGRAM_IDS=90344148

# Admin Panel (Web test): if you are not inside Telegram WebApp, you can login with this password
# VITE_ADMIN_WEB_PASSWORD=Skylife220#@

# Telegram bot username (share links + startapp)
# VITE_TELEGRAM_BOT_USERNAME=ShioriUploadBot

# Optional: IMDb score via OMDb (fallback: imdbapi.dev)
# VITE_OMDB_API_KEY=

# ─── Edge Function: sync-external-scores (Supabase Dashboard → Edge Functions → Secrets) ───
# SUPABASE_URL=              (auto in Edge runtime)
# SUPABASE_SERVICE_ROLE_KEY=   (auto in Edge runtime)
# CRON_SECRET=                 (optional; require x-cron-secret or Bearer header)
# OMDB_API_KEY=                (optional)
