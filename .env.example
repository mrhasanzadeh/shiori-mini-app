# Shiori Mini App — environment

# Required: self-hosted API (replaces Supabase for app data)
VITE_SHIORI_API_URL=http://localhost:4001

# Optional: legacy Supabase fallback (not needed when API is set)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Telegram bot username (share links + startapp + link-telegram)
# VITE_TELEGRAM_BOT_USERNAME=ShioriUploadBot

# Optional: image column override
# VITE_ANIME_IMAGE_COLUMN=cover_image

# Optional: IMDb score via OMDb (admin uses server-side OMDB_API_KEY when on API)
# VITE_OMDB_API_KEY=
